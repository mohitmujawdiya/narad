# Database (Neon PostgreSQL recommended)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# OpenAI
OPENAI_API_KEY=sk-...

# Tavily (web search)
TAVILY_API_KEY=tvly-...

# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Admin
ADMIN_USER_ID=user_xxxxx

# Demo mode (enables /demo and /playground routes without sign-up).
# Both routes share DEMO_USER_ID. /demo points at a populated showcase project
# (DEMO_PROJECT_SLUG); /playground auto-creates an empty sandbox project under
# PLAYGROUND_PROJECT_SLUG and uses normal (not stricter) rate limits.
DEMO_USER_ID=demo_user_hannibal
DEMO_PROJECT_SLUG=demo
PLAYGROUND_PROJECT_SLUG=playground

# Upstash Redis (rate limiting — optional, app works without it)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
